{
  "manifest_version": 3,
  "name": "LyricLens - Lyrics for YouTube",
  "version": "1.1.0",
  "description": "Instantly see synced, scrollable lyrics for any YouTube song. Pulls from Genius, LRCLIB & more. One click, no setup.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://music.youtube.com/*",
    "https://genius.com/*",
    "https://lrclib.net/*",
    "https://api.lyrics.ovh/*"
  ],
  "action": {
    "default_title": "Show lyrics for this video",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
